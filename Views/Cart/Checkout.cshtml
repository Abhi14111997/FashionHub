@model List<FashionHub.Models.CartItem>
@{
    ViewData["Title"] = "Checkout";
    var total = Model.Sum(c => c.Product!.Price * c.Quantity);
}

<div class="checkout-container">
    <h1>🏠 Delivery Details</h1>

    <div class="checkout-layout">
        <div class="checkout-form-section">
            <form action="/Cart/PlaceOrder" method="post">
                <div class="form-group">
                    <label>Full Name *</label>
                    <input type="text" name="customerName" placeholder="Enter your full name" required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="email" placeholder="email@example.com" required />
                    </div>
                    <div class="form-group">
                        <label>Phone *</label>
                        <input type="tel" name="phone" placeholder="+91 XXXXXXXXXX" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Full Address *</label>
                    <textarea name="address" placeholder="House No., Street, Area..." rows="3" required></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>City *</label>
                        <input type="text" name="city" placeholder="Your City" required />
                    </div>
                    <div class="form-group">
                        <label>Pincode *</label>
                        <input type="text" name="pincode" placeholder="6-digit pincode" required />
                    </div>
                </div>

                <div class="payment-section">
                    <h3>💳 Payment Method</h3>
                    <div class="payment-options">
                        <label class="pay-option active"><input type="radio" name="payment" value="cod" checked /> Cash on Delivery</label>
                        <label class="pay-option"><input type="radio" name="payment" value="upi" /> UPI Payment</label>
                        <label class="pay-option"><input type="radio" name="payment" value="card" /> Credit/Debit Card</label>
                        <label class="pay-option"><input type="radio" name="payment" value="netbanking" /> Net Banking</label>
                    </div>
                </div>

                <button type="submit" class="btn-place-order">
                    🎉 Place Order — ₹@total.ToString("N0")
                </button>
            </form>
        </div>

        <!-- Order Summary -->
        <div class="order-summary-panel">
            <h3>Order Summary</h3>
            @foreach (var item in Model)
            {
                <div class="summary-item">
                    <img src="@item.Product!.ImageUrl" alt="" />
                    <div>
                        <p>@item.Product.Name</p>
                        <small>@item.SelectedSize | @item.SelectedColor | Qty: @item.Quantity</small>
                        <strong>₹@(item.Product.Price * item.Quantity)</strong>
                    </div>
                </div>
            }
            <div class="summary-total">
                <span>Total</span>
                <strong>₹@total.ToString("N0")</strong>
            </div>
        </div>
    </div>
</div>
